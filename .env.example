# === REQUIRED SECRETS (set in GitHub Secrets for Actions) ===
GEMINI_API_KEY=your_gemini_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === OPTIONAL CONFIG ===
# Minimum Gemini score to trigger Telegram notification (0-10)
SCORE_THRESHOLD=7

# Enable dry-run mode (no Telegram messages, no DB writes)
DRY_RUN=false

# Gemini model to use (free tier)
GEMINI_MODEL=gemini-2.0-flash

# Max jobs to send to Gemini per run (budget guard)
MAX_GEMINI_CALLS_PER_RUN=200
